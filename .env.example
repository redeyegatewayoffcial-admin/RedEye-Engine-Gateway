# ==============================================================================
# NexusAI Policy Engine - Environment Configuration
# Copy this file to `.env` and fill in secrets before running.
# NEVER commit `.env` to version control.
# ==============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=nexusai
POSTGRES_PASSWORD=nexusai_secret
POSTGRES_DB=nexusai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=nexusai
CLICKHOUSE_PASSWORD=clickhouse_secret
CLICKHOUSE_DB=nexusai_telemetry

# ── Gateway (Phase 2+) ────────────────────────────────────────────────────────
GATEWAY_PORT=8080
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Rust Log Level ────────────────────────────────────────────────────────────
RUST_LOG=info
