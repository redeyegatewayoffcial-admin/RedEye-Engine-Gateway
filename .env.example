# ==============================================================================
# RedEye Policy Engine - Environment Configuration
# Copy this file to `.env` and fill in secrets before running.
# NEVER commit `.env` to version control.
# ==============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=RedEye
POSTGRES_PASSWORD=RedEye_secret
POSTGRES_DB=RedEye

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=RedEye
CLICKHOUSE_PASSWORD=clickhouse_secret
CLICKHOUSE_DB=RedEye_telemetry

# ── Gateway (Phase 2+) ────────────────────────────────────────────────────────
GATEWAY_PORT=8080
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Rust Log Level ────────────────────────────────────────────────────────────
RUST_LOG=info
